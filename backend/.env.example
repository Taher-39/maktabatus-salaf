# Copy this file to .env and fill in real values.
# NOTE: Do NOT commit secrets.

# --- Basic ---
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_STORAGE_BUCKET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend
CLIENT_URL=http://localhost:3000

# --- SSLCOMMERZ ---
# This project currently reads these directly.
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=

# Can be sandbox or live
# Sandbox default: https://sandbox.sslcommerz.com
# Live: https://securepay.sslcommerz.com
SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com

# These must point to your running backend/frontend.
SSLCOMMERZ_CALLBACK_URL=http://localhost:5000/api/orders/sslcommerz/callback
SSLCOMMERZ_SUCCESS_URL=http://localhost:3000/sslcommerz/success
SSLCOMMERZ_FAIL_URL=http://localhost:3000/sslcommerz/fail
SSLCOMMERZ_CANCEL_URL=http://localhost:3000/sslcommerz/cancel

SSLCOMMERZ_CURRENCY=BDT

