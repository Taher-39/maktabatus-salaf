          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:5000/api/review?isApproved=true&page=1&limit=10", "protocol": "http", "host": ["localhost"], "port": ["5000"], "path": ["api", "review"], "query": [{"key": "isApproved", "value": "true"}, {"key": "page", "value": "1"}, {"key": "limit", "value": "10"}]}
          }
        },
        {
          "name": "Get Book Reviews",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:5000/api/review/book/{{book_id}}?page=1&limit=5", "protocol": "http", "host": ["localhost"], "port": ["5000"], "path": ["api", "review", "book", "{{book_id}}"], "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "5"}]}
          }
        },
        {
          "name": "Mark Review as Helpful",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Authorization", "value": "Bearer {{user_token}}"}],
