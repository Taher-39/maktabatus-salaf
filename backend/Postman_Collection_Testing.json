            "body": {
              "mode": "raw",
              "raw": "{\n  \"book\": \"{{book_id_2}}\",\n  \"rating\": 4,\n  \"title\": \"অত্যন্ত গুরুত্বপূর্ণ বই\",\n  \"comment\": \"বইটি খুবই তথ্যবহুল এবং সহজবোধ্য। প্রতিটি মুসলিমের পড়া উচিত এই বই।\"\n}"
            },
            "url": {"raw": "http://localhost:5000/api/review", "protocol": "http", "host": ["localhost"], "port": ["5000"], "path": ["api", "review"]}
          }
        },
        {
