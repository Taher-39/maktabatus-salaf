          "name": "Update Review",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{user_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"title\": \"চমৎকার বই - সবার জন্য অত্যাবশ্যক\",\n  \"comment\": \"আরও বেশি সময় পড়ার পর, আমি বলতে পারি এটি সত্যিই একটি চমৎকার বই। অত্যন্ত সুপারিশকৃত।\"\n}"
            },
            "url": {"raw": "http://localhost:5000/api/review/{{review_id}}", "protocol": "http", "host": ["localhost"], "port": ["5000"], "path": ["api", "review", "{{review_id}}"]}
